{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "Warzone Helper",
    "author": "Bluscream",
    "version": "1.0.0",
    "minimum-overwolf-version": "0.200.0",
    "description": "Monitors Warzone logs/cache, cod.exe network connections (with local MaxMind geo + pings and game-server classification), the Activision status API, and on-screen game state (health, deploy, death, lobby ID) — dispatching structured events.",
    "icon": "img/icon_256.png",
    "icon_gray": "img/icon_gray_256.png",
    "launcher_icon": "img/icon.ico"
  },
  "permissions": [
    "GameInfo",
    "Media",
    "Screenshot",
    "Web",
    "Tray"
  ],
  "data": {
    "start_window": "background",
    "windows": {
      "background": {
        "file": "windows/background.html",
        "is_background_page": true,
        "show_in_taskbar": false
      },
      "log": {
        "file": "windows/log.html",
        "resizable": true,
        "show_in_taskbar": true,
        "transparent": true,
        "override_on_update": true,
        "size": { "width": 1000, "height": 640 },
        "min_size": { "width": 420, "height": 260 }
      },
      "hud": {
        "file": "windows/hud.html",
        "resizable": true,
        "show_in_taskbar": true,
        "transparent": true,
        "override_on_update": true,
        "size": { "width": 720, "height": 92 },
        "min_size": { "width": 300, "height": 60 }
      },
      "players": {
        "file": "windows/players.html",
        "resizable": true,
        "show_in_taskbar": true,
        "transparent": true,
        "override_on_update": true,
        "size": { "width": 300, "height": 560 },
        "min_size": { "width": 200, "height": 200 }
      },
      "in_game": {
        "file": "windows/in_game.html",
        "in_game_only": true,
        "transparent": true,
        "clickthrough": true,
        "resizable": false,
        "topmost": true,
        "size": { "width": 420, "height": 300 },
        "start_position": { "top": 20, "left": 20 }
      }
    },
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [27860]
    },
    "game_events": [27860],
    "externally_connectable": {
      "matches": ["ws://127.0.0.1", "http://127.0.0.1", "https://flagcdn.com"]
    },
    "protocol_override_domains": {},
    "force_browser": "user"
  }
}
