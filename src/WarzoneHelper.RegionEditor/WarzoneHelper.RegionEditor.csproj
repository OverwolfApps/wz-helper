    <TargetFramework>net48</TargetFramework>
    <UseWPF>true</UseWPF>
    <LangVersion>latest</LangVersion>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <AssemblyName>WarzoneHelper.RegionEditor</AssemblyName>
    <RootNamespace>WarzoneHelper.RegionEditor</RootNamespace>
