<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <AssemblyName>WarzoneHelper.Plugin</AssemblyName>
    <RootNamespace>WarzoneHelper.Plugin</RootNamespace>
    <ComVisible>true</ComVisible>
    <!-- Overwolf loads the DLL and all its deps from the plugins folder. -->
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.3" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\WarzoneHelper.Core\WarzoneHelper.Core.csproj" />
  </ItemGroup>

</Project>
